# Medallion Architecture — environment variables
# Copy this file to .env and fill in your values
# Never commit .env to Git

# ── PostgreSQL source database ─────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kali_source
POSTGRES_USER=kali_user
POSTGRES_PASSWORD=kali_pass

# ── ngrok tunnel (changes every session on free plan) ──
NGROK_HOST=x.tcp.eu.ngrok.io
NGROK_PORT=12345

# ── Medallion environment switch ───────────────────
# Set to 'databricks' when running in Databricks
# Defaults to 'local' for clone-and-run
MEDALLION_ENV=local

# ── Databricks Unity Catalog ───────────────────────
DATABRICKS_CATALOG=kali_demo
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_token_here